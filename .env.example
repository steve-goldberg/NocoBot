# NocoDB MCP Server Configuration
# Copy to .env and fill in your values

NOCODB_URL=http://localhost:8080
NOCODB_TOKEN=your-api-token-here
NOCODB_BASE_ID=your-base-id-here

# Optional
# NOCODB_VERIFY_SSL=false              # Set to false for self-signed certs
# MCP_API_KEY=                         # API key for HTTP client auth (generate: openssl rand -hex 32)
