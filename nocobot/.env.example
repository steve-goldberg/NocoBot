# Nocobot Configuration
# Copy this file to .env and fill in your values

# Telegram Bot Token (from @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token

# OpenRouter API Key
OPENROUTER_API_KEY=your_openrouter_api_key

# OpenRouter Model (optional, defaults to claude-sonnet-4)
# OPENROUTER_MODEL=anthropic/claude-sonnet-4

# NocoDB MCP Server URL (optional, defaults to http://ncdbmcp.lab/mcp)
# NOCODB_MCP_URL=http://ncdbmcp.lab/mcp

# Telegram Allow List (REQUIRED - bot rejects all messages if empty)
# JSON list of Telegram user IDs (numeric) or usernames
# TELEGRAM_ALLOW_FROM=["123456789", "987654321"]
